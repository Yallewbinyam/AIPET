#!/usr/bin/env bash
# AIPET X Agent — wrapper command
# Provides three subcommands: setup, test, uninstall.
# Plain Python invocations of /opt/aipet-agent/aipet_agent.py for everything else.
set -e

INSTALL_DIR="/opt/aipet-agent"
VENV_PYTHON="$INSTALL_DIR/venv/bin/python"
AGENT_SCRIPT="$INSTALL_DIR/aipet_agent.py"
CONF_DIR="/etc/aipet-agent"
CONF_FILE="$CONF_DIR/agent.conf"
EXAMPLE_FILE="$CONF_DIR/agent.conf.example"
SERVICE="aipet-agent.service"

# Colours for friendly output (only when stdout is a TTY)
if [ -t 1 ]; then
    GREEN=$(printf '\033[0;32m')
    YELLOW=$(printf '\033[1;33m')
    RED=$(printf '\033[0;31m')
    BLUE=$(printf '\033[0;34m')
    NC=$(printf '\033[0m')
else
    GREEN=""; YELLOW=""; RED=""; BLUE=""; NC=""
fi

ok()    { printf "%s[OK]%s   %s\n" "$GREEN" "$NC" "$1"; }
info()  { printf "%s[..]%s   %s\n" "$BLUE"  "$NC" "$1"; }
warn()  { printf "%s[!!]%s   %s\n" "$YELLOW" "$NC" "$1"; }
fail()  { printf "%s[XX]%s   %s\n" "$RED"   "$NC" "$1" >&2; }

require_root() {
    if [ "$(id -u)" -ne 0 ]; then
        fail "Run with sudo: sudo aipet-agent $1"
        exit 1
    fi
}

cmd_setup() {
    require_root "setup"

    echo ""
    echo "${BLUE}━━━ AIPET X Agent — interactive setup ━━━${NC}"
    echo ""
    echo "I need three things to configure this agent."
    echo ""

    # Q1 — API key
    echo "1. Your agent API key (https://app.aipet.io/settings/agents)"
    echo "   Format: aipet_<random>"
    while :; do
        printf "   Key: "
        read -r AGENT_KEY
        if printf '%s' "$AGENT_KEY" | grep -Eq '^aipet_[A-Za-z0-9_-]{20,}$'; then
            break
        fi
        warn "That doesn't look like a valid AIPET key. It must start with 'aipet_'."
    done
    echo ""

    # Q2 — label (default to hostname)
    DEFAULT_LABEL="$(hostname)"
    echo "2. Label for this agent (default: $DEFAULT_LABEL)"
    printf "   Label: "
    read -r AGENT_LABEL
    AGENT_LABEL="${AGENT_LABEL:-$DEFAULT_LABEL}"
    echo ""

    # Q3 — scan target
    echo "3. Network to scan (CIDR like 192.168.1.0/24, or 'auto')"
    printf "   Network: "
    read -r SCAN_TARGET
    SCAN_TARGET="${SCAN_TARGET:-auto}"

    if [ "$SCAN_TARGET" = "auto" ]; then
        DETECTED=$(ip -o -f inet addr show 2>/dev/null | awk '/scope global/ {print $4; exit}')
        if [ -z "$DETECTED" ]; then
            fail "Could not auto-detect a local subnet. Please re-run and enter a CIDR manually."
            exit 1
        fi
        SCAN_TARGET="$DETECTED"
        ok "Auto-detected: $SCAN_TARGET"
    elif ! printf '%s' "$SCAN_TARGET" | grep -Eq '^([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?$'; then
        fail "That doesn't look like a CIDR or IP. Examples: 192.168.1.0/24, 10.0.0.5"
        exit 1
    fi

    # API URL — read from existing conf, env, or default
    API_URL="${AIPET_API:-}"
    if [ -z "$API_URL" ] && [ -f "$CONF_FILE" ]; then
        API_URL=$(grep -E '^AIPET_API=' "$CONF_FILE" | head -1 | cut -d= -f2- || true)
    fi
    API_URL="${API_URL:-https://api.aipet.io}"

    info "Writing $CONF_FILE"
    umask 077
    cat > "$CONF_FILE" <<EOF
# AIPET X Agent — generated by aipet-agent setup on $(date -u +%Y-%m-%dT%H:%M:%SZ)
AIPET_API=$API_URL
AIPET_AGENT_KEY=$AGENT_KEY
AIPET_AGENT_LABEL=$AGENT_LABEL
AIPET_SCAN_TARGET=$SCAN_TARGET
AIPET_SCAN_INTERVAL_HOURS=24
AIPET_WATCHDOG_INTERVAL=300
AIPET_LOG_LEVEL=INFO
EOF
    chmod 640 "$CONF_FILE"
    chown root:aipet-agent "$CONF_FILE"
    ok "Configuration written (file is mode 640, owned by root:aipet-agent)"

    info "Reloading systemd"
    systemctl daemon-reload

    info "Enabling + starting aipet-agent.service"
    systemctl enable "$SERVICE" >/dev/null 2>&1
    systemctl restart "$SERVICE"
    sleep 2

    if systemctl is-active --quiet "$SERVICE"; then
        ok "Service is active"
    else
        fail "Service failed to start. Recent log lines:"
        journalctl -u "$SERVICE" -n 20 --no-pager 2>/dev/null || true
        exit 1
    fi

    cmd_test
    echo ""
    ok "Setup complete. The agent will scan $SCAN_TARGET every 24 hours."
    echo "    Status:  sudo systemctl status aipet-agent"
    echo "    Logs:    sudo journalctl -u aipet-agent -f"
}

cmd_test() {
    if [ ! -f "$CONF_FILE" ]; then
        fail "No config at $CONF_FILE. Run: sudo aipet-agent setup"
        exit 1
    fi

    # Source config in a subshell so we don't pollute environment
    AIPET_API=$(grep -E '^AIPET_API=' "$CONF_FILE" | head -1 | cut -d= -f2-)
    AIPET_AGENT_KEY=$(grep -E '^AIPET_AGENT_KEY=' "$CONF_FILE" | head -1 | cut -d= -f2-)

    if [ -z "$AIPET_AGENT_KEY" ]; then
        fail "AIPET_AGENT_KEY is not set in $CONF_FILE"
        exit 1
    fi

    echo ""
    echo "${BLUE}━━━ Self-test ━━━${NC}"

    info "Verifying connection to $AIPET_API/api/agent/keys/me"
    HTTP_CODE=$(curl -s -o /tmp/aipet-test.$$ -w "%{http_code}" --max-time 10 \
        -H "X-Agent-Key: $AIPET_AGENT_KEY" \
        "$AIPET_API/api/agent/keys/me" || echo "000")
    BODY=$(cat /tmp/aipet-test.$$ 2>/dev/null || echo "")
    rm -f /tmp/aipet-test.$$

    case "$HTTP_CODE" in
        200)
            ok "Connected to AIPET cloud (key is valid)"
            ;;
        401)
            fail "Agent key is invalid or revoked. Generate a new one in the dashboard."
            exit 1
            ;;
        000)
            fail "Could not reach $AIPET_API — check your network connection."
            exit 1
            ;;
        *)
            fail "Unexpected response from cloud (HTTP $HTTP_CODE). Body: ${BODY:0:200}"
            exit 1
            ;;
    esac

    info "Checking that the agent service is logging"
    if systemctl is-active --quiet "$SERVICE"; then
        ok "Service is running"
    else
        warn "Service is not running. Start it with: sudo systemctl start aipet-agent"
    fi

    LOG_FILE="/var/log/aipet-agent/agent.log"
    if [ -s "$LOG_FILE" ]; then
        ok "Agent log has activity ($LOG_FILE)"
    else
        warn "Agent log is empty yet — give it 30 seconds, then check $LOG_FILE"
    fi
}

cmd_uninstall() {
    require_root "uninstall"
    echo ""
    warn "This will remove the AIPET X Agent and ALL its configuration, logs,"
    warn "and the aipet-agent system user. This cannot be undone."
    printf "Type 'YES' to continue: "
    read -r CONFIRM
    if [ "$CONFIRM" != "YES" ]; then
        echo "Aborted."
        exit 0
    fi

    info "Calling apt-get purge aipet-agent"
    apt-get purge -y aipet-agent
    ok "AIPET X Agent removed."
}

cmd_status() {
    if ! systemctl is-active --quiet "$SERVICE"; then
        warn "aipet-agent.service is not running"
    else
        ok "aipet-agent.service is active"
    fi
    if [ -f "$CONF_FILE" ]; then
        ok "Config:  $CONF_FILE"
    else
        warn "Config:  not present (run: sudo aipet-agent setup)"
    fi
    echo ""
    systemctl status "$SERVICE" --no-pager 2>/dev/null | head -10 || true
}

usage() {
    cat <<EOF
AIPET X Agent — control wrapper

Usage:
  sudo aipet-agent setup      Interactive setup (API key, label, network)
  sudo aipet-agent test       Re-run cloud self-test
       aipet-agent status     Show service status
  sudo aipet-agent uninstall  Remove agent, config, user (irreversible)

Direct script (advanced):
  python3 $AGENT_SCRIPT --help

Documentation: https://docs.aipet.io/agent
EOF
}

case "${1:-}" in
    setup)     cmd_setup ;;
    test)      cmd_test ;;
    status)    cmd_status ;;
    uninstall) cmd_uninstall ;;
    ""|-h|--help|help) usage ;;
    *)
        # Pass through to the underlying script for advanced usage
        exec "$VENV_PYTHON" "$AGENT_SCRIPT" "$@"
        ;;
esac
